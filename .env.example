# Brieff GTM Dashboard — server-side credentials.
# Copy to .env.local for local dev; set the SAME vars in Vercel → Settings →
# Environment Variables. These are server-only secrets — never NEXT_PUBLIC,
# never committed. The dashboard renders (with zeros) for any source not set.

# --- Google Analytics 4 (Data API) ---
# Create a Google Cloud service account, enable "Google Analytics Data API",
# then in GA4 Admin → Property Access Management grant the service-account email
# Viewer on the Brieff Website property.
GA_PROPERTY_ID=313410833
GA_CLIENT_EMAIL=
# Paste the service-account private key on one line, in double quotes, keeping
# the \n escapes, e.g. "-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
GA_PRIVATE_KEY=

# --- HubSpot (Private App token) ---
# HubSpot → Settings → Integrations → Private Apps → create app.
# Scopes: crm.objects.contacts.read, crm.objects.deals.read
HUBSPOT_TOKEN=

# --- Stripe (restricted, read-only secret key) ---
# Stripe → Developers → API keys → Create restricted key, read access to
# Subscriptions and Customers.
STRIPE_SECRET_KEY=
